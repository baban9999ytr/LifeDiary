<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/Gunluk.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Handwriting"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationContentDescription="Cancel" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?android:attr/windowBackground"
            android:elevation="2dp"
            android:padding="8dp"
            android:gravity="end">

            <ImageButton
                android:id="@+id/btn_undo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Undo" />
                
            <ImageButton
                android:id="@+id/btn_clear"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear All" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btn_done"
                style="@style/Gunluk.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Done"
                android:layout_marginEnd="8dp" />
        </LinearLayout>


        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FDFBF7">
            
            <com.mustafagoksal.diary.HandwritingView
                android:id="@+id/handwriting_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
                
        </FrameLayout>


        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/windowBackground"
            android:elevation="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btn_pen_black"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:backgroundTint="#000000"
                    android:layout_marginEnd="8dp"
                    android:insetBottom="0dp"
                    android:insetTop="0dp"
                    app:cornerRadius="20dp" />

                <Button
                    android:id="@+id/btn_pen_brown"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:backgroundTint="#5C4033"
                    android:layout_marginEnd="8dp"
                    android:insetBottom="0dp"
                    android:insetTop="0dp"
                    app:cornerRadius="20dp" />

                <Button
                    android:id="@+id/btn_pen_blue"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:backgroundTint="#1E88E5"
                    android:layout_marginEnd="8dp"
                    android:insetBottom="0dp"
                    android:insetTop="0dp"
                    app:cornerRadius="20dp" />
                    
                <Button
                    android:id="@+id/btn_pen_red"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:backgroundTint="#E53935"
                    android:layout_marginEnd="8dp"
                    android:insetBottom="0dp"
                    android:insetTop="0dp"
                    app:cornerRadius="20dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:background="@color/divider"
                    android:layout_marginHorizontal="8dp" />

                <Button
                    android:id="@+id/btn_eraser"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    style="@style/Gunluk.Button.Secondary"
                    android:text="@string/Eraser"
                    android:textAllCaps="false"
                    android:insetBottom="0dp"
                    android:insetTop="0dp" />
            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
