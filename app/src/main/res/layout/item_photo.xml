<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="80dp"
    android:layout_height="80dp"
    android:layout_marginEnd="8dp">

    <ImageView
        android:id="@+id/iv_photo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/photo_cover_desc" />

    <TextView
        android:id="@+id/tv_set_cover"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:background="@color/shadow"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:text="@string/set_as_cover"
        android:textSize="11sp"
        android:textColor="@color/warm_white" />

    <ImageView
        android:id="@+id/iv_cover_badge"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|end"
        android:padding="2dp"
        android:visibility="gone"
        android:src="@android:drawable/star_big_on"
        app:tint="@color/accent_gold"
        android:contentDescription="@string/cover_photo" />

</FrameLayout>
