<?xml version="1.0" encoding="utf-8"?>
<!-- activity_login.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true">


    <View
        android:id="@+id/top_band"
        android:layout_width="0dp"
        android:layout_height="5dp"
        android:background="?attr/colorSecondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_band">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="600dp"
            android:paddingHorizontal="36dp"
            android:paddingBottom="40dp">


            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="64dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="?attr/colorSecondary"
                android:contentDescription="@string/desc_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <TextView
                android:id="@+id/tv_app_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/login_title"
                android:textSize="42sp"
                android:fontFamily="serif"
                android:textColor="?attr/colorOnSurface"
                android:letterSpacing="0.08"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_logo" />


            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/login_subtitle"
                android:textSize="15sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:textColor="@color/ink_medium"
                android:letterSpacing="0.04"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_app_title" />


            <View
                android:id="@+id/ornament_line_left"
                android:layout_width="60dp"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8dp"
                android:background="@color/parchment_dark"
                app:layout_constraintBottom_toBottomOf="@id/ornament_dot"
                app:layout_constraintEnd_toStartOf="@id/ornament_dot"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

            <View
                android:id="@+id/ornament_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/shape_dot"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

            <View
                android:id="@+id/ornament_line_right"
                android:layout_width="60dp"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:layout_marginStart="8dp"
                android:background="@color/parchment_dark"
                app:layout_constraintBottom_toBottomOf="@id/ornament_dot"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ornament_dot"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />


            <androidx.cardview.widget.CardView
                android:id="@+id/card_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ornament_dot">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_username_label"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="@string/hint_empty_content"
                        android:hint="@string/login_username_hint"
                        android:textColorHint="@color/hint_text"
                        android:textColor="@color/ink_brown"
                        android:textSize="18sp"
                        android:fontFamily="serif"
                        android:background="@null"
                        android:inputType="textPersonName"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:paddingVertical="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="18dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_password"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/et_password"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:autofillHints="@string/hint_password"
                            android:hint="@string/hint_password"
                            android:textColorHint="@color/hint_text"
                            android:textColor="@color/ink_brown"
                            android:textSize="18sp"
                            android:fontFamily="serif"
                            android:background="@null"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"
                            android:maxLines="1"
                            android:paddingVertical="4dp" />

                        <ImageButton
                            android:id="@+id/btn_toggle_password"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_menu_view"
                            app:tint="?android:attr/textColorSecondary"
                            android:contentDescription="@string/desc_toggle_password" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <Button
                android:id="@+id/btn_login"
                style="@style/Gunluk.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/login_button"
                android:textAllCaps="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_username" />


            <TextView
                android:id="@+id/tv_bottom_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/login_bottom_note"
                android:textSize="12sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:textColor="@color/hint_text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_login" />


            <LinearLayout
                android:id="@+id/layout_register_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_bottom_note">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_no_account"
                    android:textSize="13sp"
                    android:fontFamily="serif"
                    android:textColor="?android:attr/textColorSecondary" />

                <TextView
                    android:id="@+id/tv_go_register"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_register_link"
                    android:textSize="13sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:textColor="?attr/colorSecondary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
